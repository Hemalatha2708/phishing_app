# Phishing Detection App - Environment Configuration
# Copy this to .env and fill in your own values

# Flask Configuration
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=phishing

# Model Paths
MODEL_PATH_RF=rf_model.pkl
MODEL_PATH_XGB=xgb_model.pkl

# Logging
LOG_LEVEL=INFO
LOG_FILE=phishing_app.log
